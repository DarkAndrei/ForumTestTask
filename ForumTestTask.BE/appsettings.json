{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=db;Port=5432;Database=${DB_NAME};Username=postgres;Password=${SA_PASSWORD};SSL Mode=Prefer;Trust Server Certificate=true;"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://localhost",
      "https://localhost:443"
    ],
    "AllowCredentials": true
  }
}